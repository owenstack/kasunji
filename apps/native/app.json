{
  "expo": {
    "scheme": "kasunji",
    "userInterfaceStyle": "automatic",
    "orientation": "default",
    "web": {
      "bundler": "metro"
    },
    "name": "kasunji",
    "slug": "kasunji",
    "plugins": ["expo-font", [
      "expo-splash-screen", {
        "resizeMode": "contain",
        "backgroundColor": "#ebebd3",
        "image": "./assets/images/splash-icon.png",
        "imageWidth": 200
      }
    ]],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
